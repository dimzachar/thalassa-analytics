# BigQuery intelligence settings
THALASSA_BQ_PROJECT=your_project
THALASSA_BQ_DATASET=thalassa
THALASSA_BQ_LOCATION=EU
THALASSA_INTELLIGENCE_TABLE=thalassa.intelligence_snapshots

# LLM provider selection
LLM_PROVIDER=openrouter

# Google Gemini settings
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenRouter settings
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Anthropic settings
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Intelligence generation model settings
GENERATION_MODEL=google/gemini-2.0-flash-exp:free
GENERATION_MAX_TOKENS=2000
GENERATION_TEMPERATURE=0.2

# Retry and tracing
MAX_RETRIES=3
RETRY_DELAY_BASE=1.0
LLM_TRACE_ENABLED=false
LLM_TRACE_HEAD_CHARS=500
LLM_TRACE_TAIL_CHARS=300
